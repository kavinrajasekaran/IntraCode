{
  "name": "interagent",
  "version": "1.0.0",
  "description": "The shared brain for AI agents — multi-agent coordination broker with MCP + HTTP API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "interagent": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js start",
