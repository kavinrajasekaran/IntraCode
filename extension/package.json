{
  "name": "interagent-broker",
  "displayName": "InterAgent Multi-Agent Broker",
  "description": "Dashboard and controller for the InterAgent Multi-Agent Context Broker",
  "version": "0.3.2",
  "publisher": "interagent",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "interagent.openBroker", "title": "Open Broker Dashboard", "category": "InterAgent" },
      { "command": "interagent.startServer", "title": "Start Broker Server", "category": "InterAgent" },
      { "command": "interagent.stopServer",  "title": "Stop Broker Server",  "category": "InterAgent" }
    ],
    "configuration": {
      "title": "InterAgent Broker",
      "properties": {
        "interagent.brokerPort": {
          "type": "number",
          "default": 3737,
          "description": "Port for the InterAgent Broker HTTP API"
        },
        "interagent.brokerPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to api-server.js. Leave blank to auto-detect from workspace."
        },
        "interagent.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the broker when VS Code opens"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.3"
  }
}
